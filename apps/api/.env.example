# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vulpi?schema=public"

# Authentication
JWT_SECRET="super-secret-jwt-key"
JWT_EXPIRATION="1d"

# Google SSO
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# Microsoft SSO
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_CALLBACK_URL="http://localhost:4000/api/auth/microsoft/callback"

# SMTP Configuration (Email Service)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
SMTP_FROM="your-email@example.com"
SMTP_FROM_NAME="Vulpi Invoice System"

# Frontend URL (for links in emails)
FRONTEND_URL="http://localhost:3000"
